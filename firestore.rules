rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios con sesión iniciada (tú y la dueña del negocio) pueden leer y escribir.
    // Nadie más puede ver ni modificar nada, aunque conozca la URL de la app.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
